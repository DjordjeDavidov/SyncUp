generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model activities {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id            String                  @db.Uuid
  community_id          String?                 @db.Uuid
  category_id           String?                 @db.Uuid
  title                 String                  @db.VarChar(140)
  description           String?
  location_text         String?                 @db.VarChar(255)
  city                  String?                 @db.VarChar(100)
  country               String?                 @db.VarChar(100)
  start_time            DateTime                @db.Timestamptz(6)
  max_participants      Int?
  image_url             String?
  image_path            String?
  status                activity_status         @default(OPEN)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  invite_visibility     invite_visibility       @default(PUBLIC)
  activity_categories   activity_categories?    @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  communities           communities?            @relation(fields: [community_id], references: [id], onUpdate: NoAction)
  users                 users                   @relation(fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  activity_participants activity_participants[]
  notifications         notifications[]
  posts                 posts[]
  reports               reports[]

  @@index([category_id], map: "idx_activities_category_id")
  @@index([city], map: "idx_activities_city")
  @@index([community_id], map: "idx_activities_community_id")
  @@index([creator_id], map: "idx_activities_creator_id")
  @@index([invite_visibility], map: "idx_activities_invite_visibility")
  @@index([start_time], map: "idx_activities_start_time")
  @@index([status], map: "idx_activities_status")
}

model activity_categories {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String                      @unique @db.VarChar(100)
  slug                      String                      @unique @db.VarChar(120)
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  activities                activities[]
  user_activity_preferences user_activity_preferences[]
}

model activity_participants {
  activity_id String     @db.Uuid
  user_id     String     @db.Uuid
  joined_at   DateTime   @default(now()) @db.Timestamptz(6)
  activities  activities @relation(fields: [activity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([activity_id, user_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model blocks {
  blocker_id                     String   @db.Uuid
  blocked_id                     String   @db.Uuid
  created_at                     DateTime @default(now()) @db.Timestamptz(6)
  users_blocks_blocked_idTousers users    @relation("blocks_blocked_idTousers", fields: [blocked_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_blocks_blocker_idTousers users    @relation("blocks_blocker_idTousers", fields: [blocker_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([blocker_id, blocked_id])
}

model communities {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id            String                @db.Uuid
  name                String                @db.VarChar(120)
  slug                String                @unique @db.VarChar(140)
  description         String?
  city                String?               @db.VarChar(100)
  country             String?               @db.VarChar(100)
  visibility          community_visibility  @default(PUBLIC)
  cover_url           String?
  cover_path          String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  category            String?               @db.VarChar(120)
  custom_category     String?               @db.VarChar(120)
  activities          activities[]
  users               users                 @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  community_chat      community_chats?
  community_interests community_interests[]
  community_members   community_members[]
  community_vibe_tags community_vibe_tags[]
  notifications       notifications[]
  posts               posts[]
  reports             reports[]

  @@index([city], map: "idx_communities_city")
  @@index([owner_id], map: "idx_communities_owner_id")
  @@index([visibility], map: "idx_communities_visibility")
}

model follows {
  follower_id                       String   @db.Uuid
  following_id                      String   @db.Uuid
  created_at                        DateTime @default(now()) @db.Timestamptz(6)
  users_follows_follower_idTousers  users    @relation("follows_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_follows_following_idTousers users    @relation("follows_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([follower_id, following_id])
  @@index([follower_id], map: "idx_follows_follower_id")
  @@index([following_id], map: "idx_follows_following_id")
}

model community_interests {
  community_id String      @db.Uuid
  interest_id  String      @db.Uuid
  communities  communities @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  interests    interests   @relation(fields: [interest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([community_id, interest_id])
}

model community_chats {
  id           String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  community_id String                    @unique @db.Uuid
  created_at   DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime                  @default(now()) @db.Timestamptz(6)
  messages     community_chat_messages[]
  communities  communities               @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([community_id], map: "idx_community_chats_community_id")
}

model community_chat_messages {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  community_chat_id String          @db.Uuid
  sender_id         String          @db.Uuid
  message           String
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)
  community_chats   community_chats @relation(fields: [community_chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users           @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([community_chat_id], map: "idx_community_chat_messages_chat_id")
  @@index([created_at(sort: Desc)], map: "idx_community_chat_messages_created_at")
  @@index([sender_id], map: "idx_community_chat_messages_sender_id")
}

model community_members {
  community_id String                @db.Uuid
  user_id      String                @db.Uuid
  role         community_member_role @default(MEMBER)
  joined_at    DateTime              @default(now()) @db.Timestamptz(6)
  communities  communities           @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([community_id, user_id])
}

model community_vibe_tags {
  community_id String      @db.Uuid
  vibe_tag_id  String      @db.Uuid
  communities  communities @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vibe_tags    vibe_tags   @relation(fields: [vibe_tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([community_id, vibe_tag_id])
}

model interests {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @unique @db.VarChar(100)
  slug                String                @unique @db.VarChar(120)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  community_interests community_interests[]
  user_interests      user_interests[]
}

model languages {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String           @unique @db.VarChar(10)
  name           String           @unique @db.VarChar(100)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  user_languages user_languages[]
}

model notifications {
  id                                         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                    String            @db.Uuid
  actor_id                                   String?           @db.Uuid
  type                                       notification_type
  title                                      String            @db.VarChar(180)
  body                                       String?
  related_user_id                            String?           @db.Uuid
  related_post_id                            String?           @db.Uuid
  related_community_id                       String?           @db.Uuid
  related_activity_id                        String?           @db.Uuid
  read                                       Boolean           @default(false)
  created_at                                 DateTime          @default(now()) @db.Timestamptz(6)
  users_notifications_actor_idTousers        users?            @relation("notifications_actor_idTousers", fields: [actor_id], references: [id], onUpdate: NoAction)
  activities                                 activities?       @relation(fields: [related_activity_id], references: [id], onUpdate: NoAction)
  communities                                communities?      @relation(fields: [related_community_id], references: [id], onUpdate: NoAction)
  posts                                      posts?            @relation(fields: [related_post_id], references: [id], onUpdate: NoAction)
  users_notifications_related_user_idTousers users?            @relation("notifications_related_user_idTousers", fields: [related_user_id], references: [id], onUpdate: NoAction)
  users_notifications_user_idTousers         users             @relation("notifications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_notifications_created_at")
  @@index([read], map: "idx_notifications_read")
  @@index([user_id], map: "idx_notifications_user_id")
}

model post_likes {
  post_id    String   @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  posts      posts    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, user_id])
}

model post_saves {
  post_id    String   @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  posts      posts    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, user_id])
}

model posts {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_id         String            @db.Uuid
  community_id      String?           @db.Uuid
  activity_id       String?           @db.Uuid
  content           String
  image_url         String?
  image_path        String?
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @db.Timestamptz(6)
  location_text     String?           @db.VarChar(255)
  max_participants  Int?
  poll_ends_at      DateTime?         @db.Timestamptz(6)
  poll_question     String?           @db.VarChar(280)
  post_type         post_type         @default(STANDARD_POST)
  starts_at         DateTime?         @db.Timestamptz(6)
  title             String?           @db.VarChar(180)
  invite_visibility invite_visibility @default(PUBLIC)
  notifications     notifications[]
  poll_options      poll_options[]
  poll_votes        poll_votes[]
  post_comments     post_comments[]
  post_likes        post_likes[]
  post_saves        post_saves[]
  activities        activities?       @relation(fields: [activity_id], references: [id], onUpdate: NoAction)
  users             users             @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  communities       communities?      @relation(fields: [community_id], references: [id], onUpdate: NoAction)
  reports           reports[]

  @@index([activity_id], map: "idx_posts_activity_id")
  @@index([author_id], map: "idx_posts_author_id")
  @@index([community_id], map: "idx_posts_community_id")
  @@index([created_at(sort: Desc)], map: "idx_posts_created_at")
  @@index([invite_visibility], map: "idx_posts_invite_visibility")
  @@index([post_type], map: "idx_posts_post_type")
}

model post_comments {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String   @db.Uuid
  user_id    String   @db.Uuid
  content    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  posts      posts    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_post_comments_created_at")
  @@index([post_id], map: "idx_post_comments_post_id")
  @@index([user_id], map: "idx_post_comments_user_id")
}

model poll_options {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String       @db.Uuid
  label      String       @db.VarChar(160)
  position   Int
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  posts      posts        @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  poll_votes poll_votes[]

  @@index([post_id], map: "idx_poll_options_post_id")
}

model poll_votes {
  option_id    String       @db.Uuid
  post_id      String       @db.Uuid
  user_id      String       @db.Uuid
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  poll_options poll_options @relation(fields: [option_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts        posts        @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, user_id])
  @@index([option_id], map: "idx_poll_votes_option_id")
}

model profiles {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String             @unique @db.Uuid
  full_name          String             @db.VarChar(100)
  bio                String?
  avatar_url         String?
  avatar_path        String?
  cover_url          String?
  cover_path         String?
  city               String?            @db.VarChar(100)
  country            String?            @db.VarChar(100)
  profile_visibility profile_visibility @default(PUBLIC)
  social_mode        social_mode        @default(JUST_CHAT)
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  users              users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([city], map: "idx_profiles_city")
  @@index([country], map: "idx_profiles_country")
  @@index([social_mode], map: "idx_profiles_social_mode")
}

model direct_message_threads {
  id           String                               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at   DateTime                             @default(now()) @db.Timestamptz(6)
  participants direct_message_thread_participants[]
  messages     direct_messages[]
}

model direct_message_thread_participants {
  thread_id              String                 @db.Uuid
  user_id                String                 @db.Uuid
  joined_at              DateTime               @default(now()) @db.Timestamptz(6)
  direct_message_threads direct_message_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([thread_id, user_id])
  @@index([user_id], map: "idx_direct_message_thread_participants_user_id")
}

model direct_messages {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id              String                 @db.Uuid
  sender_id              String                 @db.Uuid
  message                String
  created_at             DateTime               @default(now()) @db.Timestamptz(6)
  updated_at             DateTime               @default(now()) @db.Timestamptz(6)
  users                  users                  @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  direct_message_threads direct_message_threads @relation(fields: [thread_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_direct_messages_created_at")
  @@index([sender_id], map: "idx_direct_messages_sender_id")
  @@index([thread_id], map: "idx_direct_messages_thread_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reports {
  id                                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id                         String             @db.Uuid
  target_type                         report_target_type
  target_user_id                      String?            @db.Uuid
  target_post_id                      String?            @db.Uuid
  target_community_id                 String?            @db.Uuid
  target_activity_id                  String?            @db.Uuid
  reason                              String
  status                              report_status      @default(OPEN)
  admin_note                          String?
  created_at                          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                          DateTime           @default(now()) @db.Timestamptz(6)
  users_reports_reporter_idTousers    users              @relation("reports_reporter_idTousers", fields: [reporter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  activities                          activities?        @relation(fields: [target_activity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  communities                         communities?       @relation(fields: [target_community_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts                               posts?             @relation(fields: [target_post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_reports_target_user_idTousers users?             @relation("reports_target_user_idTousers", fields: [target_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([reporter_id], map: "idx_reports_reporter_id")
  @@index([status], map: "idx_reports_status")
  @@index([target_type], map: "idx_reports_target_type")
}

model user_activity_preferences {
  user_id             String              @db.Uuid
  category_id         String              @db.Uuid
  activity_categories activity_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, category_id])
}

model user_interests {
  user_id     String    @db.Uuid
  interest_id String    @db.Uuid
  interests   interests @relation(fields: [interest_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, interest_id])
}

model user_languages {
  user_id     String    @db.Uuid
  language_id String    @db.Uuid
  languages   languages @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, language_id])
}

model user_vibe_tags {
  user_id     String    @db.Uuid
  vibe_tag_id String    @db.Uuid
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vibe_tags   vibe_tags @relation(fields: [vibe_tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, vibe_tag_id])
}

model users {
  id                                                             String                               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                          String                               @unique @db.Citext
  username                                                       String                               @unique @db.VarChar(30)
  password_hash                                                  String
  role                                                           user_role                            @default(USER)
  status                                                         user_status                          @default(ACTIVE)
  email_verified                                                 Boolean                              @default(false)
  verification_status                                            verification_status                  @default(UNVERIFIED)
  created_at                                                     DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at                                                     DateTime                             @default(now()) @db.Timestamptz(6)
  activities                                                     activities[]
  activity_participants                                          activity_participants[]
  blocks_blocks_blocked_idTousers                                blocks[]                             @relation("blocks_blocked_idTousers")
  blocks_blocks_blocker_idTousers                                blocks[]                             @relation("blocks_blocker_idTousers")
  communities                                                    communities[]
  community_chat_messages                                        community_chat_messages[]
  community_members                                              community_members[]
  direct_message_thread_participants                             direct_message_thread_participants[]
  direct_messages                                                direct_messages[]
  follows_follows_follower_idTousers                             follows[]                            @relation("follows_follower_idTousers")
  follows_follows_following_idTousers                            follows[]                            @relation("follows_following_idTousers")
  notifications_notifications_actor_idTousers                    notifications[]                      @relation("notifications_actor_idTousers")
  notifications_notifications_related_user_idTousers             notifications[]                      @relation("notifications_related_user_idTousers")
  notifications_notifications_user_idTousers                     notifications[]                      @relation("notifications_user_idTousers")
  poll_votes                                                     poll_votes[]
  post_comments                                                  post_comments[]
  post_likes                                                     post_likes[]
  post_saves                                                     post_saves[]
  posts                                                          posts[]
  profiles                                                       profiles?
  reports_reports_reporter_idTousers                             reports[]                            @relation("reports_reporter_idTousers")
  reports_reports_target_user_idTousers                          reports[]                            @relation("reports_target_user_idTousers")
  user_activity_preferences                                      user_activity_preferences[]
  user_interests                                                 user_interests[]
  user_languages                                                 user_languages[]
  user_vibe_tags                                                 user_vibe_tags[]
  verification_requests_verification_requests_reviewed_byTousers verification_requests[]              @relation("verification_requests_reviewed_byTousers")
  verification_requests_verification_requests_user_idTousers     verification_requests[]              @relation("verification_requests_user_idTousers")

  @@index([role], map: "idx_users_role")
  @@index([status], map: "idx_users_status")
  @@index([verification_status], map: "idx_users_verification_status")
}

model verification_requests {
  id                                             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                        String              @db.Uuid
  message                                        String?
  document_url                                   String?
  document_path                                  String?
  status                                         verification_status @default(PENDING)
  reviewed_by                                    String?             @db.Uuid
  reviewed_at                                    DateTime?           @db.Timestamptz(6)
  created_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  users_verification_requests_reviewed_byTousers users?              @relation("verification_requests_reviewed_byTousers", fields: [reviewed_by], references: [id], onUpdate: NoAction)
  users_verification_requests_user_idTousers     users               @relation("verification_requests_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model vibe_tags {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @unique @db.VarChar(100)
  slug                String                @unique @db.VarChar(120)
